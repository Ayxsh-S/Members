<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members</title>
    <link rel="stylesheet" href="https://unpkg.com/milligram/dist/milligram.min.css">
</head>
<body>
    <nav class="container">
        <a href="/">Home</a>
        <% if (!currentUser) { %>
            <a href="/signup">Sign up</a>
            <a href="/login">Login</a>
        <% } else { %>
            <a href="/messages/new">Create a new message</a>
            <a href="/join">Join the club</a>
            <a href="/logout">Logout</a>
            <h3>Hi <%= currentUser.first_name %></h3>
        <% } %>    
    </nav>
    <main class="container">
        <%- body %>
    </main>
</body>
</html>